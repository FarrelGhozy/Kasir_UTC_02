# ============================================
# Server Configuration
# ============================================
PORT=5000
NODE_ENV=development

# ============================================
# Database — MongoDB Connection URI
# ============================================
# Local (backend non-Docker):
MONGODB_URI=mongodb://localhost:27018/bengkel_utc
# Docker internal:
# MONGODB_URI=mongodb://mongo_db:27017/bengkel_utc

# ============================================
# Authentication — JWT Secret (WAJIB DIUBAH!)
# ============================================
# Generate dengan: openssl rand -hex 32
# JANGAN gunakan nilai default di production!
JWT_SECRET=change_this_in_production_min_32_chars

# ============================================
# WhatsApp Gateway (WAHA)
# ============================================
WAHA_URL=http://localhost:8000
# Untuk Docker internal:
# WAHA_URL=http://waha:8000
WAHA_SESSION=default
WAHA_API_KEY=change_this_in_production
# Webhook secret untuk autentikasi endpoint /api/waha-webhook
# Set ini di WAHA dashboard > Webhook > query parameter: token=your_secret
WAHA_WEBHOOK_SECRET=

# ============================================
# Gmail SMTP (App Password 16 digit)
# ============================================
# Aktifkan 2FA Gmail, lalu buat App Password
EMAIL_USER=bengkelutc@gmail.com
EMAIL_PASS=your_app_password

# ============================================
# Fitur Tambahan
# ============================================
CORS_ORIGIN=
IS_CAMPUS_EVENT=false
